PORT=3001
JWT_SECRET=troque_esta_chave_por_um_segredo_forte
JWT_EXPIRES_IN=8h
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://seudominio.com.br,https://www.seudominio.com.br

# Senhas iniciais dos usuarios mock.
# Defina valores fortes localmente e troque-os antes de qualquer ambiente compartilhado.
SEED_ADMIN_PASSWORD=defina_uma_senha_forte
SEED_SUPERVISOR_PASSWORD=defina_uma_senha_forte
SEED_DEFAULT_PASSWORD=defina_uma_senha_forte

# MySQL
# Em Docker na VPS, use host.docker.internal.
# Fora do Docker, use localhost ou o host do banco.
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=transforma_app
DB_PASSWORD=troque_esta_senha
DB_NAME=transforma_db

# Modo de dados: 'mock' ou 'mysql'
DATA_MODE=mysql
